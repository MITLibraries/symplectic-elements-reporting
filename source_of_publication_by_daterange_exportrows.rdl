<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="pubdata_datasource">
      <DataSourceReference>/elements-mit-prod/Data Sources/ElementsReporting</DataSourceReference>
      <rd:SecurityType>DataBase</rd:SecurityType>
      <rd:DataSourceID>5e759db1-4733-4a2f-b147-1c79a7090b0c</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>pubdata_datasource</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Date_1">
            <Value>=Parameters!Date_1.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Date_2">
            <Value>=Parameters!Date_2.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
-- Source of Publication by User Supplied Date Range (carlj, modifying original SQL from Lucian Parau, 2022-07-12)
-- Get start/end dates for query from user entered parameters: Date_1 and Date_2 (carlj, 2022-07-13)
-- Allow export all retrieved rows (carlj, 2023-01-12)

-- DECLARE THE NEEDED VARIABLES:

-- Get the ID of Recruitment Method label scheme
DECLARE @RecruitmentMethodSchemeID INT = (SELECT ID FROM [Label Scheme] WHERE [Name]='c-recruitment-method')
-- Get the ID of OA Faculty Policy
DECLARE @OAFacultyPolicyID INT = (SELECT ID FROM [OA Scheme] WHERE [display Name] = 'Faculty Policy')
-- Get the publication URL part
DECLARE @PublicationURL NVARCHAR(200) = (SELECT g.[Website Base URL]+'viewobject.html?cid=1&amp;id=' FROM [Global Settings] g)

SELECT @PublicationURL + CAST(p.[ID] AS NVARCHAR) "Elements Publication URL"
	,pRecord.[record-created-at-source-date] "Repository Creation Date"
	,p.[publication-date] "Publication Date"
	,p.[Type] "Publication Type"
	,pRecord.[Data Source Proprietary ID] [DSpace ID]
	,ISNULL(pLabel.[Label],'No Label') "Recruitment Method"
	-- return 'no label' if recruitment method is null (empty). otherwise return value for recruitment method (2023-01-10, carlj)
	,ISNULL(oaPolicy.[Display Name],'Not in Faculty Policy') "OA Policy"
FROM [Publication] p
-- Consider only publications that are live in DSpace
JOIN [Publication Record] pRecord
	ON p.[ID] = pRecord.[Publication ID]
	AND  pRecord.[Data Source] = 'DSpace' 
	AND pRecord.[repository-status] = 'Public' 
LEFT JOIN [Publication Label] pLabel
	ON p.[ID] = pLabel.[Publication ID] AND pLabel.[Scheme ID] = @RecruitmentMethodSchemeID
-- Join with OA Policy to check if the publication is part of Faculty Policy
LEFT JOIN [Publication OA Scheme State] pOAPolicy
	ON p.[ID] = pOAPolicy.[Publication ID] AND pOAPolicy.[OA Scheme ID] = @OAFacultyPolicyID
LEFT JOIN [OA Scheme] oaPolicy
	ON pOAPolicy.[OA Scheme ID] = oaPolicy.ID AND oaPolicy.[ID] = @OAFacultyPolicyID

-- Use the below line to filter by year or user entered start/end dates
-- WHERE YEAR(pRecord.[record-created-at-source-date]) &gt; 1900 --change the year value

WHERE pRecord.[record-created-at-source-date] &gt;= @Date_1 AND pRecord.[record-created-at-source-date] &lt;= @Date_2
-- Limit to Recruitment Method 'No Label' records (carlj, 2023-01-11)
AND pLabel.Label is NULL

ORDER BY pRecord.[record-created-at-source-date] DESC, pLabel.Label </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Elements_Publication_URL">
          <DataField>Elements Publication URL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Repository_Creation_Date">
          <DataField>Repository Creation Date</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="Publication_Date">
          <DataField>Publication Date</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="Publication_Type">
          <DataField>Publication Type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DSpace_ID">
          <DataField>DSpace ID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Recruitment_Method">
          <DataField>Recruitment Method</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="OA_Policy">
          <DataField>OA Policy</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
